# Copy this file to .env for local development.
# NEVER commit a real .env file — it's already in .gitignore.
# In Railway, set these as Variables on the adaptiv-automation-hub service instead.

# Required for the Daily Brief route (POST /run-daily-brief)
NOTION_API_KEY=
NOTION_DATABASE_DAILY_BRIEFS=

# Required for the Stripe Revenue Agent (POST /run-revenue-sync, POST /run-full-brief)
# STRIPE_RESTRICTED_KEY must be a RESTRICTED key (rk_live_.../rk_test_...), never a
# full secret key. Read-only on: Customers, Subscriptions, Checkout Sessions,
# Invoices, Prices, Products, Balance Transactions. No write scopes. See README.
NOTION_DATABASE_SALES=
NOTION_DATABASE_APPROVALS=
STRIPE_RESTRICTED_KEY=
STRIPE_PRICE_ATHLETE=
STRIPE_PRICE_COACH_SCHOOL=
STRIPE_PRICE_COACH_TEAM=

# Required for the Railway Health Agent (POST /run-railway-health, POST /run-full-brief)
# RAILWAY_API_TOKEN must be a PROJECT token (Project Settings -> Tokens), not an
# account/workspace token — project tokens authenticate via a different header and
# are scoped to a single project + environment. See README. Read-only: this agent
# never restarts, redeploys, or changes anything in Railway.
NOTION_DATABASE_RAILWAY_HEALTH=
RAILWAY_API_TOKEN=
RAILWAY_FRONTEND_SERVICE=adaptive-athletics-frontend
RAILWAY_BACKEND_SERVICE=adaptive-athletics-backend
BACKEND_HEALTH_URL=

# Required for Google Doc + Email Delivery (POST /run-full-brief, GET /auth/google,
# GET /oauth2callback, POST /create-test-doc, POST /send-test-email)
# OAuth only — never a Google password. See README Step 5A-5D for exact setup.
# GOOGLE_REFRESH_TOKEN is produced by visiting /auth/google once after deploying;
# it is not something you type in yourself.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://YOUR-AUTOMATION-HUB-URL.up.railway.app/oauth2callback
GOOGLE_REFRESH_TOKEN=
GOOGLE_DOC_FOLDER_ID=
FOUNDER_EMAIL=

# Optional — SMS Summary via Twilio (POST /run-full-brief, POST /send-test-sms)
# Additive/opt-in: leave SMS_ENABLED unset or false to skip this entirely — no
# other route depends on these. See README Step 6A-6D for exact setup.
# TWILIO_FROM_NUMBER and FOUNDER_PHONE_NUMBER must both be E.164 format
# (e.g. +15551234567). This service only ever sends to FOUNDER_PHONE_NUMBER.
SMS_ENABLED=false
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
FOUNDER_PHONE_NUMBER=

# Required for the Product/Bug Agent (POST /submit-bug, POST /submit-feedback,
# POST /run-product-triage, POST /run-full-brief)
# NOTION_DATABASE_TASKS and NOTION_DATABASE_APPROVALS are additive here, same
# as the rest of this service: /submit-bug still writes the bug row even if
# they're unset — it just skips creating the Task/Approval row for that
# submission. NOTION_DATABASE_APPROVALS is already required above (Step 3/4).
NOTION_DATABASE_PRODUCT_BUGS=
NOTION_DATABASE_BETA_FEEDBACK=
NOTION_DATABASE_TASKS=

# Required for the Film AI Build Team (POST /create-film-ai-mvp-plan,
# POST /run-film-ai-planning, POST /run-full-brief)
# PLANNING ONLY — see README Step 8 and lib/filmAIPlanningAgent.js. This
# service never runs computer vision and never touches real athlete video.
# NOTION_DATABASE_AGENT_REPORTS is only required by /run-film-ai-planning
# (it files a report row there); /create-film-ai-mvp-plan only needs
# NOTION_DATABASE_FILM_AI_ROADMAP.
NOTION_DATABASE_FILM_AI_ROADMAP=
NOTION_DATABASE_AGENT_REPORTS=

# Schema exists in Notion (Clip/Sport/Skill/Angle/Lighting/Result/
# Confidence/Notes) for the future QA/demo phase, but no route in this
# service reads or writes to it yet — do NOT wire up real athlete clips
# here until the Step 8H privacy gate (review, consent, deletion policy,
# secure storage plan) is cleared.
NOTION_DATABASE_FILM_AI_TEST_CLIPS=

# Not used yet in this version, but reserved for a future phase
NOTION_DATABASE_SOCIAL_METRICS=
NOTION_DATABASE_IDEAS=

# Deferred — not needed until real Film AI computer vision / video storage
# is built (post privacy-gate). Do not set these yet.
# FILM_AI_API_URL=
# FILM_AI_STORAGE_BUCKET=
# FILM_AI_MAX_UPLOAD_MB=
# FILM_AI_ENABLED=false

# Local dev only — Railway sets PORT automatically in production
PORT=3000
